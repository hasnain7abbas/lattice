{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lattice",
  "version": "0.1.0",
  "identifier": "com.lattice.crystal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lattice — Crystal Structures in Motion",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0a0a0c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Crystal structures, animated.",
    "longDescription": "Lattice is an animation-first crystal structure explorer. Switch between BCC, FCC, diamond, NaCl and more — scrub through transitions, inspect Miller planes, and learn solid-state physics through motion.",
    "copyright": "© 2026 Lattice"
  }
}
